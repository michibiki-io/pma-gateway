{
  "name": "pma-gateway-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "check": "vite build",
    "test:unit": "node --test src/lib/text.test.js src/lib/audit-log.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chrome": "playwright test --project=desktop-chrome",
    "test:e2e:webkit": "playwright test --project=desktop-webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari"
  },
  "dependencies": {
    "@fluentui/svg-icons": "^1.1.325",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "flowbite": "latest",
    "flowbite-svelte": "latest",
    "lucide-svelte": "^1.0.1",
    "svelte": "latest",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/postcss": "latest",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "latest",
    "vite": "latest"
  }
}
